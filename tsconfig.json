{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ESNext",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "removeComments": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "moduleResolution": "node",
    "jsx": "react",
    "allowJs": false,
    "noEmitOnError": true
  },
  "include": ["src"]
}
